---
interface Props {
  name: string;
  rating: number;
  text: string;
  source?: string;
}

const { name, rating, text, source = 'google' } = Astro.props;
---

<div class="bg-white border border-gray-200 rounded-lg p-6">
  <!-- Stars -->
  <div class="flex gap-0.5 text-gold" aria-label={`${rating} out of 5 stars`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class:list={['w-5 h-5', i < rating ? 'fill-gold text-gold' : 'fill-gray-200 text-gray-200']}
        viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
  </div>

  <!-- Review text -->
  <blockquote class="mt-4 text-sm text-gray-700 leading-relaxed">
    "{text}"
  </blockquote>

  <!-- Author -->
  <div class="mt-4 flex items-center justify-between">
    <p class="text-sm font-medium text-charcoal">{name}</p>
    {source === 'google' && (
      <span class="text-xs text-gray-400">Google Review</span>
    )}
  </div>
</div>
