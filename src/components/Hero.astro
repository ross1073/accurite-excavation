---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import business from '../data/business.json';
import ContactForm from './ContactForm.astro';

interface Props {
  headline: string;
  subheadline?: string;
  ctaText?: string;
  ctaLink?: string;
  showPhone?: boolean;
  backgroundImage?: ImageMetadata;
  compact?: boolean;
  showForm?: boolean;
}

const {
  headline,
  subheadline,
  ctaText = 'Get a Free Estimate',
  ctaLink = '/free-estimate',
  showPhone = true,
  backgroundImage,
  compact = false,
  showForm = false,
} = Astro.props;
---

<section
  class:list={[
    'relative bg-charcoal text-white overflow-hidden',
    compact && !showForm ? 'py-12 lg:py-16' : 'py-16 lg:py-24',
  ]}
>
  {backgroundImage && (
    <div class="absolute inset-0">
      <Image
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
        widths={[800, 1200, 1920]}
        sizes="100vw"
      />
      <div class="absolute inset-0 bg-charcoal/70"></div>
    </div>
  )}

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {showForm ? (
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <!-- Left: Text content -->
        <div class="lg:pt-4">
          <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
            {headline}
          </h1>
          {subheadline && (
            <p class="mt-4 text-lg lg:text-xl text-gray-200">{subheadline}</p>
          )}
          {showPhone && (
            <div class="mt-8">
              <a
                href={`tel:${business.phoneTel}`}
                class="inline-flex items-center gap-2 bg-white text-charcoal px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Call {business.phone}
              </a>
            </div>
          )}
        </div>
        <!-- Right: Contact Form -->
        <div>
          <ContactForm variant="hero" />
        </div>
      </div>
    ) : (
      <div class="max-w-3xl">
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight">
          {headline}
        </h1>
        {subheadline && (
          <p class="mt-4 text-lg lg:text-xl text-gray-200">{subheadline}</p>
        )}
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          {showPhone && (
            <a
              href={`tel:${business.phoneTel}`}
              class="inline-flex items-center justify-center gap-2 bg-white text-charcoal px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call {business.phone}
            </a>
          )}
          <a
            href={ctaLink}
            class="inline-flex items-center justify-center bg-gold-dark text-white px-6 py-3 rounded-lg font-semibold hover:bg-gold-dark/90 transition-colors"
          >
            {ctaText}
          </a>
        </div>
      </div>
    )}
  </div>
</section>
