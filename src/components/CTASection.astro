---
import business from '../data/business.json';
import ContactForm from './ContactForm.astro';

interface Props {
  headline?: string;
  subheadline?: string;
  showForm?: boolean;
}

const {
  headline = 'Ready to Start Your Project?',
  subheadline = 'Call us today for a free estimate or fill out our quick form.',
  showForm = false,
} = Astro.props;
---

<section class="bg-charcoal text-white py-12 lg:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading text-2xl lg:text-3xl font-bold">{headline}</h2>
    <p class="mt-3 text-gray-300 max-w-2xl mx-auto">{subheadline}</p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={`tel:${business.phoneTel}`}
        class="inline-flex items-center gap-2 bg-white text-charcoal px-8 py-4 rounded-lg font-semibold text-lg hover:bg-gray-100 transition-colors"
        data-source="cta-section"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {business.phone}
      </a>
      <a
        href="/free-estimate"
        class="inline-flex items-center bg-gold-dark text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-gold-dark/90 transition-colors"
      >
        Get a Free Estimate
      </a>
    </div>

    {showForm && (
      <div class="mt-10 max-w-xl mx-auto">
        <ContactForm variant="hero" heading="" />
      </div>
    )}
  </div>
</section>
