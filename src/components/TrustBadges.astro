---
import business from '../data/business.json';
---

<section class="bg-white py-10 lg:py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-center gap-8 lg:gap-12">

      <!-- BBB A+ Rating -->
      <a
        href={business.social.bbb}
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center gap-1 w-[110px] text-center group"
        aria-label="BBB Accredited Business - A+ Rating"
      >
        <div class="flex flex-col items-center">
          <div
            class="text-2xl font-extrabold tracking-tight leading-none"
            style="color: #00529b;"
          >
            BBB
          </div>
          <div
            class="text-[9px] font-semibold uppercase tracking-widest mt-0.5"
            style="color: #00529b;"
          >
            Accredited Business
          </div>
          <div
            class="mt-1.5 w-9 h-9 rounded-full flex items-center justify-center text-white text-lg font-extrabold"
            style="background-color: #f0b323;"
          >
            A+
          </div>
        </div>
      </a>

      <!-- Google Reviews 4.9 -->
      <a
        href={business.social.google}
        target="_blank"
        rel="noopener noreferrer"
        class="flex flex-col items-center gap-1 w-[110px] text-center group"
        aria-label={`Google Reviews - ${business.reviews.rating} stars from ${business.reviews.count} reviews`}
      >
        <!-- Google G SVG -->
        <svg width="36" height="36" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          <path fill="none" d="M0 0h48v48H0z"/>
        </svg>
        <!-- Stars -->
        <div class="flex items-center gap-0.5" aria-hidden="true">
          {[1,2,3,4,5].map(() => (
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="#FBBC05" xmlns="http://www.w3.org/2000/svg">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <div class="text-sm font-bold text-gray-800">{business.reviews.rating} <span class="font-normal text-gray-500 text-xs">({business.reviews.count})</span></div>
        <div class="text-[10px] text-gray-500 uppercase tracking-wide">Google Reviews</div>
      </a>

      <!-- Utah Licensed E100 -->
      <div class="flex flex-col items-center w-[110px]">
        <img
          src="/images/badges/utah-e100-licensed.png"
          alt="Utah State Licensed E100 Excavation Contractor"
          width="100"
          height="100"
          loading="lazy"
          class="object-contain"
        />
      </div>

      <!-- Licensed & Insured -->
      <div class="flex flex-col items-center w-[110px]">
        <img
          src="/images/badges/licensed-insured.png"
          alt="Licensed and Insured Excavation Contractor"
          width="100"
          height="100"
          loading="lazy"
          class="object-contain"
        />
      </div>

      <!-- Established 2010 -->
      <div class="flex flex-col items-center w-[110px]">
        <img
          src="/images/badges/established-2010.png"
          alt="Established 2010 - 16 Years Experience"
          width="100"
          height="100"
          loading="lazy"
          class="object-contain"
        />
      </div>

    </div>
  </div>
</section>
