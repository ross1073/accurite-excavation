---
import { Image } from 'astro:assets';
import business from '../data/business.json';
import services from '../data/services.json';
import locations from '../data/locations.json';
import logo from '../assets/images/accurite-logo-full.webp';

const phone = business.phone;
const phoneTel = business.phoneTel;
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0">
        <Image
          src={logo}
          alt="AccuRite Excavation & Hauling"
          class="h-10 lg:h-14 w-auto"
          loading="eager"
          width={280}
          height={105}
          quality={80}
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
        <!-- Services Dropdown -->
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-charcoal hover:text-gold-dark transition-colors"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white border border-gray-200 rounded-lg shadow-lg py-2 w-64">
              {services.map(service => (
                <a
                  href={`/services/${service.slug}`}
                  class="block px-4 py-2 text-sm text-charcoal hover:bg-gold/10 hover:text-gold-dark transition-colors"
                >
                  {service.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Service Areas Dropdown -->
        <div class="relative group">
          <button
            type="button"
            class="flex items-center gap-1 text-sm font-medium text-charcoal hover:text-gold-dark transition-colors"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Service Areas
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white border border-gray-200 rounded-lg shadow-lg py-2 w-56 max-h-80 overflow-y-auto">
              {locations.map(loc => (
                <a
                  href={`/locations/${loc.slug}`}
                  class="block px-4 py-2 text-sm text-charcoal hover:bg-gold/10 hover:text-gold-dark transition-colors"
                >
                  {loc.name}, UT
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href="/about" class="text-sm font-medium text-charcoal hover:text-gold-dark transition-colors">About</a>
        <a href="/safety" class="text-sm font-medium text-charcoal hover:text-gold-dark transition-colors">Safety</a>
        <a href="/gallery" class="text-sm font-medium text-charcoal hover:text-gold-dark transition-colors">Gallery</a>
        <a href="/reviews" class="text-sm font-medium text-charcoal hover:text-gold-dark transition-colors">Reviews</a>
        <a href="/contact" class="text-sm font-medium text-charcoal hover:text-gold-dark transition-colors">Contact</a>
      </nav>

      <!-- CTA + Phone -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`tel:${phoneTel}`}
          class="flex items-center gap-2 text-sm font-semibold text-charcoal hover:text-gold-dark transition-colors"
          aria-label={`Call us at ${phone}`}
          data-source="header"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {phone}
        </a>
        <a
          href="/free-estimate"
          class="bg-gold-dark text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-gold-dark/90 transition-colors"
        >
          Free Estimate
        </a>
      </div>

      <!-- Mobile: Phone + Hamburger -->
      <div class="flex items-center gap-3 lg:hidden">
        <a
          href={`tel:${phoneTel}`}
          class="p-2 text-gold-dark"
          aria-label={`Call us at ${phone}`}
          data-source="mobile-header"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </a>
        <button
          type="button"
          id="mobile-menu-btn"
          class="p-2 text-charcoal"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open navigation menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden fixed inset-0 top-16 bg-white z-40 overflow-y-auto"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
  >
    <nav class="px-4 py-6 space-y-1" aria-label="Mobile navigation">
      <div class="pb-3 mb-3 border-b border-gray-200">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Services</p>
        {services.map(service => (
          <a href={`/services/${service.slug}`} class="block py-2 text-charcoal hover:text-gold-dark">
            {service.name}
          </a>
        ))}
      </div>
      <div class="pb-3 mb-3 border-b border-gray-200">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Service Areas</p>
        <div class="grid grid-cols-2 gap-x-4">
          {locations.map(loc => (
            <a href={`/locations/${loc.slug}`} class="block py-1.5 text-sm text-charcoal hover:text-gold-dark">
              {loc.name}
            </a>
          ))}
        </div>
      </div>
      <a href="/about" class="block py-2 text-charcoal hover:text-gold-dark font-medium">About</a>
      <a href="/safety" class="block py-2 text-charcoal hover:text-gold-dark font-medium">Safety</a>
      <a href="/gallery" class="block py-2 text-charcoal hover:text-gold-dark font-medium">Gallery</a>
      <a href="/reviews" class="block py-2 text-charcoal hover:text-gold-dark font-medium">Reviews</a>
      <a href="/contact" class="block py-2 text-charcoal hover:text-gold-dark font-medium">Contact</a>

      <div class="pt-4 mt-4 border-t border-gray-200 space-y-3">
        <a
          href={`tel:${phoneTel}`}
          class="flex items-center justify-center gap-2 w-full py-3 bg-charcoal text-white rounded-lg font-semibold"
          data-source="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {phone}
        </a>
        <a
          href="/free-estimate"
          class="block text-center w-full py-3 bg-gold-dark text-white rounded-lg font-semibold"
        >
          Get a Free Estimate
        </a>
      </div>
    </nav>
  </div>
</header>
