---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  name: string;
  description: string;
  image?: ImageMetadata;
}

const { slug, name, description, image } = Astro.props;
---

<a
  href={`/services/${slug}`}
  class="group block bg-white border border-gray-200 rounded-lg overflow-hidden hover:border-gold-dark hover:shadow-md transition-all"
>
  {image && (
    <div class="overflow-hidden">
      <Image
        src={image}
        alt={name}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        widths={[400, 600]}
        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
        quality={65}
      />
    </div>
  )}
  <div class="p-6">
    <h3 class="font-heading text-lg font-bold text-charcoal group-hover:text-gold-dark transition-colors">
      {name}
    </h3>
    <p class="mt-2 text-sm text-gray-600 line-clamp-2">{description}</p>
    <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-gold-dark">
      Learn more
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
