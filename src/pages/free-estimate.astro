---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';

import business from '../data/business.json';
---

<BaseLayout
  title="Free Excavation Estimate | AccuRite Excavation"
  description="Request a free excavation estimate from AccuRite Excavation in Ogden, UT. Residential, commercial, and government projects. Call (801) 814-6975."
  schemaType="page"
>
  <Hero
    headline="Get Your Free Estimate"
    subheadline="Tell us about your project and we'll provide a no-obligation quote — usually within one business day."
    compact={true}
    showPhone={true}
  />

  <TrustBar />

  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="font-heading text-2xl font-bold text-charcoal">
          Prefer to Talk? Call Shawn Directly
        </h2>
        <a
          href={`tel:${business.phoneTel}`}
          class="mt-4 inline-flex items-center gap-2 text-2xl font-bold text-gold-dark hover:underline"
        >
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {business.phone}
        </a>
      </div>

      <div class="border-t border-gray-200 pt-8">
        <h2 class="font-heading text-2xl font-bold text-charcoal text-center mb-6">
          Or Fill Out the Form Below
        </h2>

        <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 min-h-[500px] flex items-center justify-center">
          <!-- LeadConnector form will be embedded here -->
          <div class="text-center text-gray-500">
            <p class="font-medium">Estimate Request Form</p>
            <p class="mt-1 text-sm">LeadConnector form loading...</p>
            <noscript>
              <p class="mt-4">
                Please call us at <a href={`tel:${business.phoneTel}`} class="text-gold-dark underline">{business.phone}</a> to request an estimate.
              </p>
            </noscript>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
