---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import ContactForm from '../components/ContactForm.astro';

import business from '../data/business.json';
---

<BaseLayout
  title="Free Excavation Estimate | AccuRite Excavation"
  description="Request a free excavation estimate from AccuRite Excavation in Ogden, UT. Residential, commercial, and government projects. Call (801) 814-6975."
  schemaType="page"
>
  <Hero
    headline="Get Your Free Estimate"
    subheadline="Tell us about your project and we'll provide a no-obligation quote — usually within one business day."
    compact={true}
    showPhone={true}
  />

  <TrustBar />

  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Left: value prop -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-charcoal">
            Prefer to Talk? Call Shawn Directly
          </h2>
          <a
            href={`tel:${business.phoneTel}`}
            class="mt-4 inline-flex items-center gap-2 text-2xl font-bold text-gold-dark hover:underline"
          >
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {business.phone}
          </a>

          <div class="mt-10">
            <h3 class="font-heading text-xl font-bold text-charcoal mb-4">Why Choose AccuRite?</h3>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-dark mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Family-owned and operated since {business.founded} — you work directly with the owner</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-dark mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Utah E100 licensed and fully insured for all project types</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-dark mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Trusted by federal agencies, municipalities, and homeowners across the Wasatch Front</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-dark mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Free, no-obligation estimates — usually within one business day</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-dark mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{business.reviews.rating}-star rated with {business.reviews.count} five-star Google reviews</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Right: form -->
        <div>
          <ContactForm variant="hero" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
