---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import services from '../data/services.json';

const galleryImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/gallery/*.{jpg,jpeg,png,webp}', { eager: true });
const images = Object.entries(galleryImages).map(([path, mod]) => ({
  src: mod.default,
  alt: path.split('/').pop()?.replace(/\.[^.]+$/, '').replace(/-/g, ' ').replace(/\d+$/, '').trim() || 'AccuRite Excavation project',
}));
---

<BaseLayout
  title="Project Gallery | AccuRite Excavation"
  description="Browse photos of AccuRite Excavation projects across Northern Utah. Residential basements, retaining walls, demolition, utilities, and more."
  schemaType="page"
>
  <Hero
    headline="Our Work Speaks for Itself"
    subheadline="Browse real projects completed across the Wasatch Front."
    compact={true}
  />

  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filter Buttons -->
      <div class="flex flex-wrap justify-center gap-2 mb-10">
        <button
          class="gallery-filter px-4 py-2 rounded-full text-sm font-medium border border-gold-dark text-gold-dark bg-white hover:bg-gold-dark hover:text-white transition-colors"
          data-filter="all"
          aria-pressed="true"
        >
          All Projects
        </button>
        {services.map(service => (
          <button
            class="gallery-filter px-4 py-2 rounded-full text-sm font-medium border border-gray-300 text-gray-600 bg-white hover:border-gold-dark hover:text-gold-dark transition-colors"
            data-filter={service.slug}
            aria-pressed="false"
          >
            {service.name}
          </button>
        ))}
      </div>

      <!-- Gallery Grid -->
      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {images.map(({ src, alt }) => (
          <div class="gallery-item overflow-hidden rounded-lg bg-gray-100">
            <Image
              src={src}
              alt={alt}
              class="w-full h-64 object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
              widths={[400, 800]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Links -->
  <section class="py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-600 mb-4">Want to see what we can do for your project?</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/services" class="inline-flex items-center gap-1 text-gold-dark font-medium hover:underline">
          View all services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/reviews" class="inline-flex items-center gap-1 text-gold-dark font-medium hover:underline">
          Read customer reviews
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/about" class="inline-flex items-center gap-1 text-gold-dark font-medium hover:underline">
          About AccuRite
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<script src="/js/gallery-filter.js" defer></script>
