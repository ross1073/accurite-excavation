---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Excavation Blog | AccuRite Excavation"
  description="Expert excavation tips, project spotlights, and Northern Utah construction insights from AccuRite Excavation."
  schemaType="page"
>
  <Hero
    headline="Excavation Insights & Project Updates"
    subheadline="Tips, guides, and project spotlights from Northern Utah's trusted excavation contractor."
    compact={true}
  />

  <section class="py-12 lg:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {posts.length > 0 ? (
        <div class="space-y-8">
          {posts.map(post => (
            <article class="border-b border-gray-200 pb-8">
              <a href={`/blog/${post.id}`} class="group">
                <h2 class="font-heading text-xl lg:text-2xl font-bold text-charcoal group-hover:text-gold-dark transition-colors">
                  {post.data.title}
                </h2>
              </a>
              <div class="mt-2 flex items-center gap-3 text-sm text-gray-500">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.author && <span>by {post.data.author}</span>}
              </div>
              <p class="mt-3 text-gray-600 leading-relaxed">{post.data.description}</p>
              <a
                href={`/blog/${post.id}`}
                class="mt-3 inline-flex items-center gap-1 text-gold-dark font-medium hover:underline"
              >
                Read more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-gray-500">Blog posts coming soon. Check back for excavation tips and project updates.</p>
        </div>
      )}
    </div>
  </section>

  <CTASection />
</BaseLayout>
