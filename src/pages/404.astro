---
import BaseLayout from '../layouts/BaseLayout.astro';
import business from '../data/business.json';
import services from '../data/services.json';
---

<BaseLayout
  title="Page Not Found | AccuRite Excavation"
  description="The page you're looking for doesn't exist. Browse our excavation services or call (801) 814-6975."
  noindex={true}
  hideBreadcrumbs={true}
>
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-6xl lg:text-8xl font-bold text-gold-dark">404</h1>
      <h2 class="mt-4 font-heading text-2xl lg:text-3xl font-bold text-charcoal">Page Not Found</h2>
      <p class="mt-4 text-gray-600">
        The page you're looking for may have been moved or no longer exists. Let us help you find what you need.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center bg-gold-dark text-white px-6 py-3 rounded-lg font-semibold hover:bg-gold-dark/90 transition-colors"
        >
          Go to Homepage
        </a>
        <a
          href={`tel:${business.phoneTel}`}
          class="inline-flex items-center gap-2 text-charcoal font-semibold hover:text-gold-dark transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call {business.phone}
        </a>
      </div>

      <div class="mt-12">
        <h3 class="font-heading text-lg font-bold text-charcoal mb-4">Popular Services</h3>
        <div class="flex flex-wrap justify-center gap-2">
          {services.slice(0, 6).map(service => (
            <a
              href={`/services/${service.slug}`}
              class="px-4 py-2 border border-gray-200 rounded-full text-sm text-gray-600 hover:border-gold-dark hover:text-gold-dark transition-colors"
            >
              {service.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
