---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import FAQSection from '../../components/FAQSection.astro';
import CTASection from '../../components/CTASection.astro';

import business from '../../data/business.json';
import servicesData from '../../data/services.json';
import locationsData from '../../data/locations.json';
import reviews from '../../data/reviews.json';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map(location => ({
    params: { slug: location.id.replace(/\.md$/, '') },
    props: { entry: location },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const slug = entry.id.replace(/\.md$/, '');

// Match JSON data for this location
const locationJson = locationsData.find(l => l.slug === slug);

// Get nearby cities with names
const nearbyCities = (locationJson?.nearby || [])
  .map(nearbySlug => locationsData.find(l => l.slug === nearbySlug))
  .filter(Boolean);

// Filter reviews for this location
const locationReviews = reviews.filter(r => r.location === slug);

// FAQs from frontmatter
const faqs = entry.data.faqs || [];

// Projects from frontmatter
const projects = entry.data.projects || [];

// Landmark images via import.meta.glob
const landmarkImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/locations/*-landmark.png', { eager: true });
const landmarkKey = `/src/assets/images/locations/${slug}-landmark.png`;
const landmarkImage = landmarkImages[landmarkKey]?.default;
---

<BaseLayout
  title={entry.data.metaTitle || entry.data.title + ' | AccuRite Excavation'}
  description={entry.data.metaDescription || entry.data.description}
  schemaType="location"
  schemaData={{ location: locationJson, faqs }}
>
  <Hero
    headline={`Excavation Services in ${entry.data.city}, ${business.address.state}`}
    subheadline={entry.data.description}
    compact={true}
  />

  <TrustBar />

  {landmarkImage && (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
      <Image
        src={landmarkImage}
        alt={`${entry.data.city}, Utah — excavation services by AccuRite`}
        class="w-full h-64 object-cover rounded-lg"
        loading="eager"
        widths={[640, 1024, 1536]}
      />
    </div>
  )}

  <!-- Local Intro & Content -->
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-gray max-w-none [&>h2]:font-heading [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-charcoal [&>h2]:mt-10 [&>h2]:mb-4 [&>h3]:font-heading [&>h3]:text-xl [&>h3]:font-bold [&>h3]:text-charcoal [&>p]:text-gray-600 [&>p]:leading-relaxed [&>ul]:text-gray-600 [&>ol]:text-gray-600">
        <Content />
      </div>
    </div>
  </section>

  <!-- Soil & Permit Info -->
  {(entry.data.soilInfo || entry.data.permitInfo) && (
    <section class="bg-gray-50 py-12 lg:py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-8">
        {entry.data.soilInfo && (
          <div>
            <h2 class="font-heading text-xl font-bold text-charcoal">
              Soil Conditions in {entry.data.city}
            </h2>
            <p class="mt-3 text-gray-600 leading-relaxed">{entry.data.soilInfo}</p>
          </div>
        )}
        {entry.data.permitInfo && (
          <div>
            <h2 class="font-heading text-xl font-bold text-charcoal">
              Permits & Regulations
            </h2>
            <p class="mt-3 text-gray-600 leading-relaxed">{entry.data.permitInfo}</p>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Services Available -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl lg:text-3xl font-bold text-charcoal text-center mb-8">
        Excavation Services in {entry.data.city}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesData.map(service => (
          <ServiceCard
            slug={service.slug}
            name={service.name}
            description={service.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Local Testimonials -->
  {locationReviews.length > 0 && (
    <section class="bg-gray-50 py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-2xl font-bold text-charcoal text-center mb-8">
          Reviews from {entry.data.city} Customers
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {locationReviews.map(review => (
            <TestimonialCard
              name={review.name}
              rating={review.rating}
              text={review.text}
              source={review.source}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQs -->
  {faqs.length > 0 && (
    <FAQSection faqs={faqs} heading={`Excavation FAQs for ${entry.data.city}`} />
  )}

  <!-- Nearby Cities -->
  {nearbyCities.length > 0 && (
    <section class="py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-xl font-bold text-charcoal text-center mb-6">
          Also Serving Nearby Cities
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {nearbyCities.map(city => (
            <a
              href={`/locations/${city.slug}`}
              class="px-4 py-2 border border-gray-200 rounded-full text-sm text-gray-600 hover:border-gold-dark hover:text-gold-dark transition-colors"
            >
              {city.name}, {business.address.state}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection
    headline={`Start Your ${entry.data.city} Project Today`}
    subheadline={`Call Shawn directly or request a free estimate for your ${entry.data.city} excavation project.`}
    showForm={true}
  />
</BaseLayout>
