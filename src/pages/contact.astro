---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
import TrustBadges from '../components/TrustBadges.astro';

import business from '../data/business.json';
---

<BaseLayout
  title="Contact AccuRite Excavation | Call (801) 814-6975"
  description="Contact AccuRite Excavation in Ogden, UT. Call (801) 814-6975 for a free estimate. Serving Weber, Davis, and Morgan counties."
  schemaType="page"
>
  <Hero
    headline="Contact Us"
    subheadline="Call Shawn directly for a free estimate or fill out the form below."
    compact={true}
  />

  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-charcoal">Get In Touch</h2>

          <!-- Phone -->
          <div class="mt-8">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Phone</h3>
            <a
              href={`tel:${business.phoneTel}`}
              class="mt-2 inline-flex items-center gap-3 text-2xl font-bold text-gold-dark hover:underline"
            >
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {business.phone}
            </a>
          </div>

          <!-- Address -->
          <div class="mt-8">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Address</h3>
            <address class="mt-2 not-italic text-gray-700 leading-relaxed">
              {business.name}<br />
              {business.address.street}<br />
              {business.address.city}, {business.address.state} {business.address.zip}
            </address>
          </div>

          <!-- Hours -->
          <div class="mt-8">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Business Hours</h3>
            <dl class="mt-2 space-y-1 text-gray-700">
              {Object.entries(business.hours).map(([day, hours]) => (
                <div class="flex justify-between max-w-xs">
                  <dt class="capitalize">{day}</dt>
                  <dd class:list={[hours === 'Closed' ? 'text-gray-400' : '']}>{hours}</dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- Service Area -->
          <div class="mt-8">
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide">Service Area</h3>
            <p class="mt-2 text-gray-700">
              We serve Weber, Davis, and Morgan counties including Ogden, Layton, Bountiful, Farmington, Kaysville, Clearfield, Roy, and surrounding communities across the Wasatch Front.
            </p>
            <a href="/locations" class="mt-2 inline-flex items-center gap-1 text-gold-dark font-medium hover:underline">
              View all service areas
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <ContactForm variant="hero" heading="Request a Free Estimate" />
        </div>
      </div>
    </div>
  </section>

  <TrustBadges />
</BaseLayout>
