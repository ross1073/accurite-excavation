---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CTASection from '../components/CTASection.astro';

import business from '../data/business.json';
import reviews from '../data/reviews.json';
---

<BaseLayout
  title="Customer Reviews | AccuRite Excavation"
  description={`Read ${business.reviews.count} reviews from AccuRite Excavation customers. ${business.reviews.rating}-star average on Google. See why Northern Utah trusts us.`}
  schemaType="reviews"
>
  <Hero
    headline={`${business.reviews.rating} Stars from ${business.reviews.count} Reviews`}
    subheadline="Don't take our word for it — hear from the homeowners, contractors, and agencies who trust AccuRite."
    compact={true}
  />

  <!-- Rating Summary -->
  <section class="py-10 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <div class="flex items-center gap-2">
          <span class="text-4xl font-bold text-charcoal">{business.reviews.rating}</span>
          <div class="flex text-gold">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
        <div class="text-gray-600">
          Based on {business.reviews.count} Google reviews
        </div>
      </div>
    </div>
  </section>

  <!-- All Reviews -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {reviews.map(review => (
          <TestimonialCard
            name={review.name}
            rating={review.rating}
            text={review.text}
            source={review.source}
          />
        ))}
      </div>

      <!-- Leave a Review CTA -->
      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4">Had a great experience with AccuRite?</p>
        <a
          href="https://g.page/r/accurite-excavation/review"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-gold-dark text-white px-6 py-3 rounded-lg font-semibold hover:bg-gold-dark/90 transition-colors"
        >
          Leave Us a Google Review
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
